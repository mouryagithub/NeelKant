// Variables and arithmetic example
function main(): void {
    var x: int = 10;
    var y: int = 20;
    var sum: int = x + y;
    
    print(sum);
    
    if (sum > 25) {
        print("Sum is greater than 25");
    } else {
        print("Sum is 25 or less");
    }
    
    var counter: int = 0;
    while (counter < 5) {
        print(counter);
        counter = counter + 1;
    }
}
